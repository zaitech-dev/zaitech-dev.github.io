{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</assets/header-background.avif>; rel=preload; as=image; type=image/avif, </assets/header-background.webp>; rel=preload; as=image; type=image/webp, </assets/logo-white.avif>; rel=preload; as=image; type=image/avif, </assets/logo-white.webp>; rel=preload; as=image; type=image/webp"
        }
      ]
    },
    {
      "source": "/assets/(.*\\.(avif|webp))",
